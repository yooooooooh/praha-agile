{
  "name": "@praha-agile/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@praha-agile/biome-config": "workspace:*",
    "@praha-agile/typescript-config": "workspace:*",
    "@types/node": "^22.19.19",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
