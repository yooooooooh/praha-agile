{
  "name": "praha-agile",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "db:generate": "pnpm --filter @praha-agile/db db:generate",
    "db:migrate": "pnpm --filter @praha-agile/db db:migrate",
    "db:push": "pnpm --filter @praha-agile/db db:push",
    "db:studio": "pnpm --filter @praha-agile/db db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "turbo": "^2.5.0",
    "typescript": "^5"
  }
}
